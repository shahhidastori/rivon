{
  "name": "hotel-booking-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "tsx watch server/src/index.ts",
    "client:dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.server.json && vite build",
    "build:render": "prisma generate --schema prisma/schema.production.prisma && tsc -p tsconfig.server.json && vite build",
    "start": "NODE_ENV=production node dist/server/index.js",
    "prisma:generate": "prisma generate",
    "prisma:generate:prod": "prisma generate --schema prisma/schema.production.prisma",
    "db:migrate": "prisma migrate dev",
    "db:apply:sqlite": "sqlite3 prisma/dev.db < prisma/migrations/20260614095000_init/migration.sql",
    "db:prod:push": "prisma db push --schema prisma/schema.production.prisma",
    "db:prod:seed": "prisma generate --schema prisma/schema.production.prisma && tsx prisma/seed.ts",
    "db:seed": "tsx prisma/seed.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.5.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "multer": "^2.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prisma": "^6.9.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^8.1.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
